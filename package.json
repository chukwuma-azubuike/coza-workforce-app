{
    "name": "coza-workforce-app",
    "main": "index.js",
    "version": "2.2.6",
    "engines": {
        "node": "20.x"
    },
    "scripts": {
        "dev:start": "npx expo start --dev-client",
        "clear:cache": "npx expo start --clear",
        "dev:android": "npx expo start -c --android",
        "clean": "rm -rf .expo node_modules",
        "doctor": "npx expo-doctor",
        "check:fix": "npx expo install --check",
        "run:android-build": "eas build:run -p android --latest",
        "eas:build-prod": "eas build --clear-cache --profile production --auto-submit",
        "eas:build-preview": "eas build --clear-cache --profile preview --auto-submit",
        "eas:build-android-dev": "eas build --clear-cache --platform android --profile development",
        "eas:build-ios-dev": "eas build --clear-cache --platform ios --profile development",
        "postinstall": "npx tailwindcss -i ./global.css -o ./node_modules/.cache/nativewind/global.css",
        "format": "npx prettier . --write",
        "android": "expo run:android",
        "ios": "expo run:ios",
        "submit:prod": "eas submit --profile production",
        "submit:preview": "eas submit --profile preview",
        "prebuild": "npx expo prebuild",
        "update:preview": "APP_VARIANT=preview eas update --channel preview --environment preview",
        "update:prod": "APP_VARIANT=production eas update --channel production --environment production",
        "workflow:dev": "eas workflow:run .eas/workflows/create-development-build.yml",
        "workflow:preview": "eas workflow:run .eas/workflows/publish-preview-update.yml",
        "workflow:production": "eas workflow:run .eas/workflows/deploy-to-production.yml"
    },
